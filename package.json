{
  "name": "akds",
  "private": true,
  "version": "0.0.0",
  "packageManager": "npm@11.3.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "clean": "rm -rf node_modules dist storybook-static .turbo packages/*/node_modules packages/*/dist packages/*/.turbo apps/*/node_modules apps/*/dist apps/*/.turbo"
  },
  "devDependencies": {
    "@akds/tokens": "*",
    "@rollup/plugin-terser": "^1.0.0",
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react-vite": "^8.6.18",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "husky": "^9.1.7",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "storybook": "^8.6.18",
    "turbo": "^2.9.4",
    "typescript": "^5.4.0",
    "vite-plugin-dts": "^4.5.4",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
