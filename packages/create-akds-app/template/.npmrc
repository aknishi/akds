# Required to install @aknishi packages from the GitHub Package Registry.
# Set NPM_TOKEN in your environment, or replace with a personal access token
# that has read:packages scope.
#
# See: https://docs.github.com/en/packages/working-with-a-github-packages-registry/working-with-the-npm-registry
@aknishi:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
