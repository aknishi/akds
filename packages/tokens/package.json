{
  "name": "@aknishi/akds-tokens",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./css": {
      "types": "./dist/css/tokens.css.d.ts",
      "default": "./dist/css/tokens.css"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aknishi/akds.git",
    "directory": "packages/tokens"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean && mkdir -p dist/css && cp src/css/tokens.css dist/css/tokens.css && cp src/css/tokens.css.d.ts dist/css/tokens.css.d.ts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "build:tokens": "tsx scripts/fetch-tokens.ts",
    "build:tokens:local": "tsx scripts/build-from-collections.ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "dotenv": "^16.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
